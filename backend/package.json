{
  "name": "yachi-backend",
  "version": "1.0.0",
  "description": "Backend for Yachi marketplace app - Connecting skilled service providers with clients through a gamified marketplace experience with Ethiopian payment integration",
  "main": "server.js",
  "license": "MIT",
  "author": "Yachi Team",
  "keywords": [
    "marketplace",
    "services",
    "gamification",
    "real-time",
    "postgresql",
    "redis",
    "socket.io",
    "express",
    "ethiopian-payments",
    "telebirr",
    "chapa",
    "cbe-birr",
    "etb-payments"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "dev:debug": "cross-env NODE_ENV=development nodemon --inspect server.js",
    "prod": "cross-env NODE_ENV=production node server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:payment": "eslint services/payment/ controllers/payment/ routes/payment/",
    "lint:security": "eslint --config .eslintrc.security.js .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=\"integration\" --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=\"unit\" --runInBand",
    "test:payment": "cross-env NODE_ENV=test jest --testPathPattern=\"payment\" --runInBand",
    "test:security": "cross-env NODE_ENV=test jest --testPathPattern=\"security\" --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand",
    "test:coverage:report": "cross-env NODE_ENV=test jest --coverage --runInBand --coverageReporters=lcov",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "fixtures:load": "node database/fixtures/cli.js load",
    "fixtures:unload": "node database/fixtures/cli.js unload",
    "fixtures:list": "node database/fixtures/cli.js list",
    "fixtures:reset": "node database/fixtures/cli.js reset",
    "fixtures:load-users": "node database/fixtures/cli.js load extensive-users",
    "fixtures:load-services": "node database/fixtures/cli.js load extensive-services",
    "fixtures:load-payments": "node database/fixtures/cli.js load payment-transactions",
    "dev:reset": "npm run db:migrate:undo && npm run db:migrate && npm run fixtures:load",
    "docker:build": "docker build -t yachi-backend .",
    "docker:run": "docker run -p 5000:5000 --env-file .env yachi-backend",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:scan": "npm run security:audit && npm run lint:security",
    "dependencies:check": "npm-check -u",
    "dependencies:update": "npm update",
    "dependencies:audit": "npx depcheck",
    "clean": "rm -rf node_modules coverage dist build .cache",
    "clean:install": "npm run clean && npm install",
    "clean:modules": "rm -rf node_modules && npm install",
    "docs:generate": "jsdoc -c jsdoc.json",
    "docs:serve": "serve docs/",
    "performance:test": "artillery run performance-test.yml",
    "performance:test:payment": "artillery run performance-payments.yml",
    "health:check": "node scripts/health-check.js",
    "type-check": "tsc --noEmit",
    "payment:test": "node scripts/test-payment-gateways.js",
    "payment:webhook": "node scripts/simulate-webhook.js",
    "seed:currencies": "node database/seeders/seed-currencies.js",
    "seed:payment-methods": "node database/seeders/seed-payment-methods.js",
    "encrypt:secrets": "node scripts/encrypt-secrets.js",
    "decrypt:secrets": "node scripts/decrypt-secrets.js",
    "generate:docs:api": "node scripts/generate-api-docs.js",
    "check:env": "node scripts/check-environment.js",
    "backup:db": "node scripts/backup-database.js",
    "restore:db": "node scripts/restore-database.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.5.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lz-string": "^1.5.0",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "qs": "^6.12.1",
    "redis": "^5.8.2",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.2",
    "sharp": "^0.33.2",
    "socket.io": "^4.8.0",
    "twilio": "^5.4.0",
    "uuid": "^11.0.2",
    "validator": "^13.12.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8",
    
    // Ethiopian Payment Gateway Dependencies
    "chapa": "^1.0.7",
    "telebirr-js": "^2.0.0",
    "et-payment-utils": "^1.2.0",
    "ethiopian-currency": "^1.0.3",
    "et-phone-validator": "^1.1.0",
    
    // Security Dependencies
    "bcrypt": "^5.1.1",
    "csurf": "^1.11.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-sslify": "^1.2.0",
    "hpp": "^0.2.3",
    "rate-limit-redis": "^3.1.0",
    "request-ip": "^3.3.0",
    "xss-clean": "^0.1.4",
    
    // Utility Dependencies
    "async": "^3.2.5",
    "lodash": "^4.17.21",
    "moment-timezone": "^0.5.45",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash": "^4.17.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.19",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.12.2",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "artillery": "^2.0.12",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.0.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-jsdoc": "^50.0.0",
    "faker": "^6.6.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jsdoc": "^4.0.4",
    "nodemon": "^3.1.4",
    "npm-check": "^6.0.1",
    "prettier": "^3.3.3",
    "serve": "^14.2.3",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "cross-env": "^7.0.3",
    "depcheck": "^1.4.7",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "config",
      "services",
      "controllers",
      "routes",
      ".env"
    ],
    "ext": "js,json,ts",
    "ignore": [
      "src/**/*.test.js",
      "src/**/*.spec.js",
      "coverage",
      "logs",
      "node_modules",
      "dist",
      "*.log"
    ],
    "exec": "node server.js",
    "env": {
      "NODE_ENV": "development"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!**/node_modules/**",
      "!**/vendor/**",
      "!**/coverage/**",
      "!**/*.config.js",
      "!**/database/migrations/**",
      "!**/database/seeders/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)",
      "**/?(*.)+(spec|test).[jt]s?(x)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@models/(.*)$": "<rootDir>/models/$1",
      "^@services/(.*)$": "<rootDir>/services/$1",
      "^@controllers/(.*)$": "<rootDir>/controllers/$1",
      "^@routes/(.*)$": "<rootDir>/routes/$1",
      "^@utils/(.*)$": "<rootDir>/utils/$1",
      "^@middlewares/(.*)$": "<rootDir>/middlewares/$1",
      "^@tests/(.*)$": "<rootDir>/tests/$1"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yachi-app/yachi-backend.git"
  },
  "bugs": {
    "url": "https://github.com/yachi-app/yachi-backend/issues"
  },
  "homepage": "https://github.com/yachi-app/yachi-backend#readme",
  "private": true
}
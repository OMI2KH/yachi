{
  "name": "yachi-mobile",
  "version": "1.0.0",
  "description": "Yachi - Ethiopian Service Marketplace & Construction Platform with AI-Powered Worker Matching",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:web": "expo build:web",
    "dev": "EXPO_PUBLIC_APP_ENV=development expo start",
    "staging": "EXPO_PUBLIC_APP_ENV=staging expo start",
    "production": "EXPO_PUBLIC_APP_ENV=production expo start",
    "bundle:android": "expo build:android --type app-bundle",
    "bundle:ios": "expo build:ios --type archive",
    "publish": "expo publish",
    "publish:staging": "expo publish --release-channel staging",
    "publish:production": "expo publish --release-channel production",
    "postinstall": "patch-package",
    "prebuild": "expo prebuild",
    "clean": "expo prebuild --clean",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "doctor": "expo doctor",
    "optimize:assets": "npx expo-optimize",
    "analyze:bundle": "expo export --platform web && npx source-map-explorer dist/*.js",
    "icons:generate": "npx @expo/configure-splash-screen && npx @bam.tech/react-native-make-assets"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/netinfo": "9.4.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.7",
    "@react-navigation/material-top-tabs": "^6.6.7",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "expo": "~50.0.0",
    "expo-application": "~5.6.0",
    "expo-asset": "~9.0.0",
    "expo-av": "~13.8.2",
    "expo-barcode-scanner": "~12.7.2",
    "expo-blur": "~12.7.0",
    "expo-camera": "~13.8.2",
    "expo-checkbox": "~2.7.0",
    "expo-constants": "~15.4.0",
    "expo-device": "~5.8.0",
    "expo-file-system": "~16.0.0",
    "expo-font": "~11.10.0",
    "expo-haptics": "~12.7.0",
    "expo-image": "~1.10.0",
    "expo-image-picker": "~14.7.1",
    "expo-linking": "~6.2.2",
    "expo-location": "~16.5.0",
    "expo-media-library": "~15.8.0",
    "expo-notifications": "~0.27.0",
    "expo-secure-store": "~12.8.0",
    "expo-sensors": "~12.8.0",
    "expo-sharing": "~11.8.0",
    "expo-splash-screen": "~0.26.0",
    "expo-sqlite": "~13.0.0",
    "expo-status-bar": "~1.11.1",
    "expo-system-ui": "~2.9.0",
    "expo-updates": "~0.24.0",
    "expo-web-browser": "~12.6.0",
    "lottie-react-native": "5.1.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-get-random-values": "~1.9.0",
    "react-native-maps": "1.7.1",
    "react-native-pager-view": "6.2.3",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "13.4.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-web": "~0.19.6",
    "socket.io-client": "^4.7.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.8",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.54.0",
    "eslint-config-universe": "^12.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.3",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-native": "0.73.0"
  },
  "resolutions": {
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@sentry/.*)"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/__tests__/setup.js"
    ],
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/jest.setup.js",
      "!**/__tests__/**",
      "!**/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "babel": {
    "presets": [
      "babel-preset-expo"
    ],
    "plugins": [
      [
        "module-resolver",
        {
          "root": [
            "./"
          ],
          "alias": {
            "@components": "./components",
            "@screens": "./screens",
            "@navigation": "./navigation",
            "@services": "./services",
            "@utils": "./utils",
            "@constants": "./constants",
            "@contexts": "./contexts",
            "@hooks": "./hooks",
            "@types": "./types",
            "@assets": "./assets",
            "@styles": "./styles",
            "@config": "./config"
          }
        }
      ]
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.8.1",
  "keywords": [
    "ethiopia",
    "marketplace",
    "services",
    "construction",
    "ai-matching",
    "mobile-app",
    "react-native",
    "expo",
    "payment-gateway",
    "chapa",
    "telebirr",
    "cbe-birr",
    "government-projects",
    "worker-matching",
    "premium-features"
  ],
  "author": {
    "name": "Yachi Team",
    "email": "dev@yachi.et",
    "url": "https://yachi.et"
  },
  "contributors": [
    {
      "name": "Yachi Engineering Team",
      "email": "engineering@yachi.et"
    }
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/yachi-platform/mobile-app.git"
  },
  "bugs": {
    "url": "https://github.com/yachi-platform/mobile-app/issues"
  },
  "homepage": "https://yachi.et",
  "private": true,
  "expo": {
    "name": "Yachi",
    "slug": "yachi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "et.yachi.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Yachi needs camera access to capture service photos and verify identities.",
        "NSLocationWhenInUseUsageDescription": "Yachi uses your location to find nearby services and service providers.",
        "NSLocationAlwaysUsageDescription": "Yachi uses your location to provide better service recommendations.",
        "NSPhotoLibraryUsageDescription": "Yachi needs photo library access to upload service images and portfolio photos.",
        "NSMicrophoneUsageDescription": "Yachi needs microphone access for voice search and chat features.",
        "NSFaceIDUsageDescription": "Yachi uses Face ID for secure biometric authentication.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#10B981"
      },
      "package": "et.yachi.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyProdGoogleMapsKeyYachiEthiopia2024"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Yachi to access your camera to capture service photos and verify identities."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Yachi to use your location to find nearby services and service providers."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#10B981",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Yachi needs access to your photos to upload service images and portfolio photos."
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "prod-yachi-project-2024"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/prod-yachi-project-2024",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "newArchEnabled": false
  }
}